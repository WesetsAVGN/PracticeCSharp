<Window x:Class="TaskManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Task Manager" Height="450" Width="700">

    <DockPanel>

        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Файл">
                <MenuItem Header="Выход" Click="Exit_Click"/>
            </MenuItem>

            <MenuItem Header="Задачи">
                <MenuItem Header="Создать"
                  Command="{Binding AddTaskCommand}"/>
                <MenuItem Header="Редактировать"
                  Command="{Binding EditTaskCommand}"/>
                <MenuItem Header="Удалить"
                  Command="{Binding DeleteTaskCommand}"/>
            </MenuItem>

            <MenuItem Header="Настройки">
                <MenuItem Header="О программе"
                  Click="About_Click"/>
            </MenuItem>
        </Menu>

        <ToolBar DockPanel.Dock="Top">
            <Button Content="Создать"
                    Command="{Binding AddTaskCommand}"/>
            <Button Content="Редактировать"
                    Command="{Binding EditTaskCommand}"/>
            <Button Content="Удалить"
                    Command="{Binding DeleteTaskCommand}"/>
        </ToolBar>

        <Grid Margin="10">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <ComboBox x:Name="StatusFilter"
                      SelectionChanged="StatusFilter_Changed">
                <ComboBoxItem Content="Все"/>
                <ComboBoxItem Content="В работе"/>
                <ComboBoxItem Content="Выполнено"/>
                <ComboBoxItem Content="Отложено"/>
            </ComboBox>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10">

                <TextBox x:Name="TitleBox" Width="150"/>

                <ComboBox x:Name="PriorityBox" Width="120">
                    <ComboBoxItem Content="Низкий"/>
                    <ComboBoxItem Content="Средний"/>
                    <ComboBoxItem Content="Высокий"/>
                </ComboBox>

                <ComboBox x:Name="StatusBox" Width="120">
                    <ComboBoxItem Content="В работе"/>
                    <ComboBoxItem Content="Выполнено"/>
                    <ComboBoxItem Content="Отложено"/>
                </ComboBox>

                <Button Content="Добавить задачу"
                    Click="Add_Click"
                    Margin="5"/>
                
            </StackPanel>

            <ListBox x:Name="TaskList"
                     Grid.Row="2"
                     Margin="0,10"/>
        </Grid>
    </DockPanel>
</Window>